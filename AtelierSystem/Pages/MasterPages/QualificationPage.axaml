<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AtelierSystem.QualificationPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20">
            <TextBlock FontSize="20" FontWeight="Bold">Повышение квалификации</TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
            <Label>Текущий уровень</Label>
            <TextBox x:Name="currentLevelBox" Width="300" IsReadOnly="True"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
            <Label>Запросить уровень</Label>
            <ComboBox x:Name="levelComboBox" Width="300"></ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="sendRequestBtn" 
                    Content="Отправить заявку"
                    Padding="15,5"
                    Background="White"
                    BorderBrush="Black"
                    Cursor="Hand"
                    Click="sendRequestBtn_Click">
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="20,0,20,20">
            <TextBlock FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10">История заявок</TextBlock>
            <ScrollViewer MaxHeight="200">
                <StackPanel x:Name="requestsPanel" Spacing="5"></StackPanel>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>
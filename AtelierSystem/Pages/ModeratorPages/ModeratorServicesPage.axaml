<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="720"
             x:Class="AtelierSystem.ModeratorServicesPage"
             Background="White">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="logoImage" Width="50" Height="50" Margin="0,0,10,0"></Image>
                    <TextBlock Text="Матье" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"></TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="20">
                    
                    <Button x:Name="customBtn" 
                            Content="Кастом"
                            Padding="25,8" 
                            FontSize="14"
                            Background="White"
                            BorderBrush="Black"
                            Cursor="Hand"
                            Click="customBtn_Click">
                    </Button>
                    
                    <Button x:Name="cosplayBtn" 
                            Content="Косплей"
                            Padding="25,8" 
                            FontSize="14"
                            Background="White"
                            BorderBrush="Black"
                            Cursor="Hand"
                            Click="cosplayBtn_Click">
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Spacing="5">
                    
                    <ComboBox x:Name="sortComboBox" 
                              Width="130" 
                              SelectionChanged="sortComboBox_SelectionChanged">
                        <ComboBox.Items>
                            <ComboBoxItem>По умолчанию</ComboBoxItem>
                            <ComboBoxItem>По алфавиту (А-Я)</ComboBoxItem>
                            <ComboBoxItem>По алфавиту (Я-А)</ComboBoxItem>
                            <ComboBoxItem>По цене (возр.)</ComboBoxItem>
                            <ComboBoxItem>По цене (убыв.)</ComboBoxItem>
                        </ComboBox.Items>
                    </ComboBox>
                    
                    <TextBox x:Name="searchBox" 
                             Width="180" 
                             Watermark="Поиск"
                             TextChanged="searchBox_TextChanged">
                    </TextBox>
                    
                    <Button x:Name="addServiceBtn" 
                            Content="+ Добавить"
                            Padding="12,5"
                            Background="#2C3E50"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            Cursor="Hand"
                            Click="addServiceBtn_Click">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#34495E"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="200"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0">
                <StackPanel x:Name="servicesPanel" Margin="10" Spacing="10"></StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" 
                    BorderBrush="#CCCCCC"
                    BorderThickness="1,0,0,0"
                    Padding="10">
                <StackPanel Spacing="10">
                    <TextBlock Text="Коллекции" FontSize="16" FontWeight="Bold"></TextBlock>
                    
                    <CheckBox x:Name="animeFilter" Content="Аниме" Click="filter_Changed"></CheckBox>
                    <CheckBox x:Name="newYearFilter" Content="Новый год" Click="filter_Changed"></CheckBox>
                    <CheckBox x:Name="halloweenFilter" Content="Хэллоуин" Click="filter_Changed"></CheckBox>
                    <CheckBox x:Name="cyberpunkFilter" Content="Киберпанк" Click="filter_Changed"></CheckBox>
                    <CheckBox x:Name="noirFilter" Content="Нуар" Click="filter_Changed"></CheckBox>
                    
                    <Button x:Name="resetFilterBtn" 
                            Content="Сброс"
                            Margin="0,20,0,0"
                            Background="White"
                            BorderBrush="Black"
                            Cursor="Hand"
                            Click="resetFilterBtn_Click">
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" 
                BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    
                    <Button x:Name="prevPageBtn" 
                            Content="←"
                            Padding="10,5"
                            Background="White"
                            BorderBrush="Black"
                            Cursor="Hand"
                            Click="prevPageBtn_Click">
                    </Button>
                    
                    <TextBlock x:Name="pageInfoText" 
                               VerticalAlignment="Center"
                               Margin="10,0">
                    </TextBlock>
                    
                    <Button x:Name="nextPageBtn" 
                            Content="→"
                            Padding="10,5"
                            Background="White"
                            BorderBrush="Black"
                            Cursor="Hand"
                            Click="nextPageBtn_Click">
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
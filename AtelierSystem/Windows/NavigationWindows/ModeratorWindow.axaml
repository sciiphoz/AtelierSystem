<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="720"
        x:Class="AtelierSystem.ModeratorWindow"
        Title="Лавка Матье - Модератор"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="None"
        Width="1024"
        Height="720"
        CanResize="False"
        RequestedThemeVariant="Light"
        Background="White">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center" 
                            Margin="10,0,0,0">
                    
                    <TextBlock Text="Матье" 
                               FontSize="16" 
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>
                    
                    <TextBlock Text="Модератор"
                               FontSize="14"
                               Foreground="Gray"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center"
                            Margin="0,0,5,0">
                    
                    <Button x:Name="minimizeBtn" 
                            Content="Свернуть"
                            Padding="15,5" 
                            Margin="5,0"
                            FontSize="12"
                            Background="White"
                            BorderBrush="Black"
                            Cursor="Hand"
                            Click="minimizeBtn_Click">
                    </Button>
                    
                    <Button x:Name="closeBtn" 
                            Content="Закрыть"
                            Padding="15,5" 
                            Margin="5,0"
                            FontSize="12"
                            Background="White"
                            BorderBrush="Black"
                            Cursor="Hand"
                            Click="closeBtn_Click">
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    BorderBrush="#CCCCCC"
                    BorderThickness="0,0,1,0"
                    Background="#F8F9FA">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" 
                                HorizontalAlignment="Center" 
                                Margin="0,20,0,20">
                        <Border Width="100" 
                                Height="100" 
                                Background="#E0E0E0" 
                                CornerRadius="50">
                            <Image x:Name="logoImage" 
                                   Width="100" 
                                   Height="100">
                            </Image>
                        </Border>
                        <TextBlock Text="Лавка Матье" 
                                   FontSize="14" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0">
                        </TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="1"></Grid>

                    <StackPanel Grid.Row="2" 
                                Margin="10,0,10,20"
                                Spacing="10">
                        
                        <Border BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="moderatorNameText" 
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap">
                                </TextBlock>
                                <TextBlock Text="Модератор"
                                           FontSize="12"
                                           Foreground="Gray"
                                           Margin="0,5,0,0">
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        
                        <Button x:Name="servicesBtn" 
                                Content="Услуги"
                                Padding="10,8"
                                Background="White"
                                BorderBrush="Black"
                                Cursor="Hand"
                                Click="servicesBtn_Click">
                        </Button>
                        
                        <Button x:Name="addServiceBtn" 
                                Content="Добавить услугу"
                                Padding="10,8"
                                Background="White"
                                BorderBrush="Black"
                                Cursor="Hand"
                                Click="addServiceBtn_Click">
                        </Button>
                        
                        <Button x:Name="logoutBtn" 
                                Content="Выйти"
                                Padding="10,8"
                                Background="White"
                                BorderBrush="Black"
                                Cursor="Hand"
                                Click="logoutBtn_Click">
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Column="1" 
                            x:Name="mainContentControl"
                            Background="White"
                            VerticalContentAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>